# Primary provider — used by all notebooks
ANTHROPIC_API_KEY=sk-ant-...

# Fallback provider — set SHOWCASE_LLM=openai to route through OpenAI instead
OPENAI_API_KEY=sk-...

# Override the default model (optional)
# SHOWCASE_MODEL=anthropic/claude-sonnet-4-6
# SHOWCASE_LLM=anthropic   # or "openai"

# Module 05 A2A — endpoint for the demo A2A server (notebook spins it up locally)
A2A_SHOWCASE_ENDPOINT=http://localhost:8765
